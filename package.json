{
    "name": "whatsapp-express",
    "version": "1.0.0",
    "type": "module",
    "main": "dist/app.js",
    "scripts": {
        "dev": "nodemon --exec node --loader ts-node/esm src/app.ts",
        "build": "rimraf dist && tsc",
        "start": "node dist/app.js",
        "db:generate": "npx sequelize-cli migration:generate --name",
        "db:migrate": "npx sequelize-cli db:migrate",
        "db:migrate:undo": "npx sequelize-cli db:migrate:undo",
        "db:migrate:undo:all": "npx sequelize-cli db:migrate:undo:all",
        "lint": "eslint . --ext .js,.ts,.tsx",
        "format": "prettier --write .",
        "test": "echo \"Error: no test specified\" && exit 1"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "description": "",
    "dependencies": {
        "@google/generative-ai": "^0.24.1",
        "@sequelize/postgres": "^7.0.0-alpha.43",
        "@types/uuid": "^10.0.0",
        "@whiskeysockets/baileys": "^6.7.19",
        "bcryptjs": "^2.4.3",
        "bullmq": "^5.52.1",
        "cors": "^2.8.5",
        "csv-parser": "^3.0.0",
        "date-fns": "^4.1.0",
        "dotenv": "^16.4.5",
        "express": "^4.21.1",
        "fs": "^0.0.1-security",
        "whatsapp-express": "file:",
        "joi": "^17.13.3",
        "jsonwebtoken": "^9.0.2",
        "minio": "^8.0.5",
        "multer": "^1.4.5-lts.1",
        "nodemon": "^3.1.7",
        "pg": "^8.13.1",
        "pg-hstore": "^2.3.4",
        "rimraf": "^6.0.1",
        "sequelize": "^6.37.5"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/cors": "^2.8.17",
        "@types/csv-parse": "^1.1.12",
        "@types/dotenv": "^6.1.1",
        "@types/express": "^5.0.0",
        "@types/jsonwebtoken": "^9.0.7",
        "@types/multer": "^1.4.12",
        "@types/node": "^22.18.0",
        "cross-env": "^7.0.3",
        "eslint": "^9.19.0",
        "eslint-config-prettier": "^10.0.1",
        "eslint-plugin-prettier": "^5.2.3",
        "prettier": "^3.4.2",
        "sequelize-cli": "^6.6.2",
        "ts-node": "^10.9.2",
        "tsx": "^4.20.5",
        "typescript": "^5.8.3"
    }
}
